{
  "version": 10,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 0,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "regression",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/regression",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "regression",
      "configurePreset": "regression"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "filter": {
        "include": {
          "label": "fast"
        }
      }
    },
    {
      "name": "lint",
      "configurePreset": "debug",
      "filter": {
        "include": {
          "label": "lint"
        }
      }
    },
    {
      "name": "regression",
      "configurePreset": "regression"
    }
  ]
}
